// Schéma Prisma — Institut de Bien-Être « Le Surnaturel de Dieu »

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
  SAGE_FEMME
  ACCOMPAGNATEUR_MEDICAL
}

enum CategorieSoin {
  HAMMAM
  GOMMAGE
  AMINCISSANT
  VISAGE
  POST_ACCOUCHEMENT
  CONSEIL_ESTHETIQUE
  SAGE_FEMME
}

enum StatutRDV {
  EN_ATTENTE
  CONFIRME
  ANNULE
  TERMINE
}

enum StatutCommande {
  EN_ATTENTE
  PAYEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
}

enum VerificationStatus {
  AUCUNE
  MEMBRE_VERIFIE
  PROFESSIONNEL_SANTE
}

enum StoryType {
  TEXTE
  IMAGE
  VIDEO
}

enum StoryVisibilite {
  PUBLIC
  CONNEXIONS
}

// ─── Modèles ─────────────────────────────────────────────────────

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  passwordHash         String
  nom                  String
  prenom               String
  name                 String?          // nom complet (NextAuth)
  telephone            String?
  adresse              String?
  role                 Role             @default(CLIENT)
  photoUrl             String?
  image                String?          // avatar (NextAuth)
  ville                String?
  codeParrainage       String?          @unique
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  // ─── Profil étendu réseau social
  bio                  String?
  centresInteret       String[]
  couvertureUrl        String?
  profilPublic         Boolean          @default(true)
  pseudo               String?          @unique
  localisation         String?
  statutProfil         StatutProfil     @default(ACTIF)
  // ─── Préférences notifications
  notifLikes           Boolean          @default(true)
  notifCommentaires    Boolean          @default(true)
  notifConnexions      Boolean          @default(true)
  notifMessages        Boolean          @default(true)
  notifEvenements      Boolean          @default(true)
  notifGroupes         Boolean          @default(true)
  // ─── Relations existantes
  rendezVous           RendezVous[]
  commandes            Commande[]
  messages             Message[]
  dossierMedical       DossierMedical?
  notifications        Notification[]
  pointsFidelite       PointsFidelite?
  favoris              Favori[]
  parrainagesParrain   Parrainage[]     @relation("Parrain")
  parrainagesFilleul   Parrainage[]     @relation("Filleul")
  avis                 Avis[]
  // ─── Relations réseau social
  posts                Post[]
  commentaires         Commentaire[]
  likes                Like[]
  reactions            Reaction[]
  postsSauvegardes     PostSauvegarde[]
  connexionsEnvoyees   Connexion[]      @relation("Demandeur")
  connexionsRecues     Connexion[]      @relation("Destinataire")
  abonnements          Abonnement[]     @relation("Abonne")
  abonnes              Abonnement[]     @relation("Suivi")
  groupesMembres       MembreGroupe[]
  evenementsCreateur   Evenement[]      @relation("CreateurEvenement")
  participations       ParticipationEvenement[]
  signalementsEmis     Signalement[]    @relation("Signaleur")
  signalementsRecus    Signalement[]    @relation("Signale")
  blocagesEmis         Blocage[]        @relation("Bloqueur")
  blocagesRecus        Blocage[]        @relation("Bloque")
  mentionsConcernees   Mention[]        @relation("MentionsConcernees")
  mentionsEmises       Mention[]        @relation("MentionsEmises")
  stories              Story[]
  verificationStatus   VerificationStatus @default(AUCUNE)
  profilDetail         ProfilDetail?
  // ─── Reset mot de passe
  resetToken           String?          @unique
  resetTokenExpiry     DateTime?
  // ─── Messages médicaux (table séparée)
  messagesMedicauxEnvoyes  MessageMedical[] @relation("MessagesMedicauxEnvoyes")
  messagesMedicauxRecus    MessageMedical[] @relation("MessagesMedicauxRecus")
}

model Soin {
  id          String        @id @default(cuid())
  nom         String
  slug        String        @unique
  description String
  deroulement String?
  bienfaits   String[]
  prix        Float
  duree       Int // en minutes
  categorie   CategorieSoin
  imageUrl    String?
  actif       Boolean       @default(true)
  rendezVous  RendezVous[]
  favoris     Favori[]
  avis        Avis[]
}

model RendezVous {
  id        String    @id @default(cuid())
  userId    String
  soinId    String
  dateHeure DateTime
  statut    StatutRDV @default(EN_ATTENTE)
  notes     String?
  user      User      @relation(fields: [userId], references: [id])
  soin      Soin      @relation(fields: [soinId], references: [id])
  avis      Avis?
  createdAt DateTime  @default(now())
}

model Produit {
  id              String          @id @default(cuid())
  nom             String
  description     String
  descriptionLongue String?
  prix            Float
  prixPromo       Float?
  stock           Int             @default(0)
  imageUrl        String?
  categorie       String
  actif           Boolean         @default(true)
  lignesCommande  LigneCommande[]
  favoris         Favori[]
  createdAt       DateTime        @default(now())
}

model Commande {
  id         String         @id @default(cuid())
  userId     String
  total      Float
  statut     StatutCommande @default(EN_ATTENTE)
  paiementId String?
  user       User           @relation(fields: [userId], references: [id])
  lignes     LigneCommande[]
  createdAt  DateTime       @default(now())
}

model LigneCommande {
  id           String   @id @default(cuid())
  commandeId   String
  produitId    String
  quantite     Int
  prixUnitaire Float
  commande     Commande @relation(fields: [commandeId], references: [id])
  produit      Produit  @relation(fields: [produitId], references: [id])
}

enum MessageType {
  TEXTE
  VOCAL
  MEDIA
}

model Message {
  id             String      @id @default(cuid())
  expediteurId   String
  destinataireId String
  contenu        String
  type           MessageType @default(TEXTE)
  dureeSecondes  Int?        // durée audio pour VOCAL
  lu             Boolean     @default(false)
  replyToId      String?
  replyTo        Message?    @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]   @relation("MessageReply")
  reactions      Reaction[]  @relation("MessageReactions")
  expediteur     User        @relation(fields: [expediteurId], references: [id])
  createdAt      DateTime    @default(now())

  @@index([expediteurId, destinataireId])
  @@index([destinataireId, lu])          // conversations: comptage non-lus
  @@index([expediteurId, createdAt])     // conversations: tri par date
  @@index([destinataireId, createdAt])   // historique: pagination
}

// ─── Messages médicaux (table dédiée, totalement isolée) ─────────

model MessageMedical {
  id             String   @id @default(cuid())
  expediteurId   String
  destinataireId String
  contenu        String   // TOUJOURS chiffré (AES-256-GCM)
  lu             Boolean  @default(false)
  expediteur     User     @relation("MessagesMedicauxEnvoyes", fields: [expediteurId], references: [id])
  destinataire   User     @relation("MessagesMedicauxRecus", fields: [destinataireId], references: [id])
  createdAt      DateTime @default(now())

  @@index([expediteurId, destinataireId])
  @@index([destinataireId, lu])
  @@index([expediteurId, createdAt])
  @@index([destinataireId, createdAt])
}

model DossierMedical {
  id            String   @id @default(cuid())
  userId        String   @unique
  pathologie    String?  // chiffré
  notes         String?  // chiffré
  allergies     String?  // chiffré
  antecedents   String?  // chiffré (chirurgies, maladies passées)
  medicaments   String?  // chiffré (traitements en cours)
  groupeSanguin String?
  contactUrgence String? // chiffré
  user          User     @relation(fields: [userId], references: [id])
  mesures       MesureSante[]
  documents     DocumentMedical[]
  updatedAt     DateTime @updatedAt
}

// ─── Mesures de santé / Suivi vital ──────────────────────────────

enum TypeMesure {
  POIDS
  TENSION_ARTERIELLE
  TEMPERATURE
  GLYCEMIE
  TOUR_DE_TAILLE
  FREQUENCE_CARDIAQUE
  AUTRE
}

model MesureSante {
  id           String       @id @default(cuid())
  dossierId    String
  type         TypeMesure
  valeur       String       // ex: "75", "12/8", "37.2"
  unite        String       // ex: "kg", "mmHg", "°C"
  commentaire  String?
  dossier      DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt    DateTime     @default(now())

  @@index([dossierId, type])
  @@index([dossierId, createdAt])
}

// ─── Documents médicaux ──────────────────────────────────────────

enum TypeDocument {
  ORDONNANCE
  ANALYSE
  RADIO_IMAGERIE
  COMPTE_RENDU
  CERTIFICAT
  AUTRE
}

model DocumentMedical {
  id           String       @id @default(cuid())
  dossierId    String
  nom          String
  type         TypeDocument
  fileUrl      String       // URL Cloudinary
  taille       Int?         // en octets
  description  String?      // chiffré
  dossier      DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt    DateTime     @default(now())

  @@index([dossierId, type])
  @@index([dossierId, createdAt])
}

model Article {
  id           String   @id @default(cuid())
  titre        String
  slug         String   @unique
  contenu      String
  categorie    String   @default("Bien-être")
  tempsLecture Int      @default(3)
  imageUrl     String?
  publie       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ─── Nouveaux modèles — Améliorations ────────────────────────────

enum NotifType {
  RDV_CONFIRME
  RDV_ANNULE
  COMMANDE_PAYEE
  COMMANDE_EXPEDIEE
  NOUVEAU_MESSAGE
  FIDELITE_POINTS
  FIDELITE_RECOMPENSE
  PARRAINAGE
  // ─── Réseau social
  NOUVEAU_LIKE
  NOUVEAU_COMMENTAIRE
  NOUVELLE_CONNEXION
  DEMANDE_CONNEXION
  MENTION
  INVITATION_GROUPE
  EVENEMENT_RAPPEL
  SIGNALEMENT_TRAITE
  ANNONCE_GROUPE
  REACTION_MESSAGE
}

enum TypeFidelite {
  GAIN_RDV
  GAIN_COMMANDE
  GAIN_PARRAINAGE
  GAIN_AVIS
  DEPOT_RECOMPENSE
}

enum StatutParrainage {
  EN_ATTENTE
  ACTIF
  RECOMPENSE_ACCORDEE
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  titre     String
  message   String
  lu        Boolean   @default(false)
  lien      String?
  sourceId  String?
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId, lu])
  @@index([userId, createdAt])
}

model PointsFidelite {
  id         String               @id @default(cuid())
  userId     String               @unique
  total      Int                  @default(0)
  user       User                 @relation(fields: [userId], references: [id])
  historique HistoriqueFidelite[]
}

model HistoriqueFidelite {
  id        String         @id @default(cuid())
  pointsId  String
  points    Int
  raison    String
  type      TypeFidelite
  pointsFid PointsFidelite @relation(fields: [pointsId], references: [id])
  createdAt DateTime       @default(now())
}

model Favori {
  id        String   @id @default(cuid())
  userId    String
  soinId    String?
  produitId String?
  user      User     @relation(fields: [userId], references: [id])
  soin      Soin?    @relation(fields: [soinId], references: [id])
  produit   Produit? @relation(fields: [produitId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, soinId])
  @@unique([userId, produitId])
}

model Parrainage {
  id        String           @id @default(cuid())
  parrainId String
  filleulId String?
  code      String           @unique
  statut    StatutParrainage @default(EN_ATTENTE)
  parrain   User             @relation("Parrain", fields: [parrainId], references: [id])
  filleul   User?            @relation("Filleul", fields: [filleulId], references: [id])
  createdAt DateTime         @default(now())
}

model Avis {
  id          String     @id @default(cuid())
  userId      String
  rdvId       String     @unique
  soinId      String
  note        Int
  commentaire String?
  publie      Boolean    @default(false)
  user        User       @relation(fields: [userId], references: [id])
  rdv         RendezVous @relation(fields: [rdvId], references: [id])
  soin        Soin       @relation(fields: [soinId], references: [id])
  createdAt   DateTime   @default(now())
}

// ─── Réseau social — Communauté ──────────────────────────────────

enum StatutProfil {
  ACTIF
  EN_PAUSE
  PRO_SANTE
}

enum TypeReaction {
  JAIME
  SOUTIEN
  ENCOURAGEMENT
  BRAVO
  INSPIRATION
}

enum FormatPost {
  TEXTE
  IMAGE
  VIDEO
  LIEN
  DOCUMENT
}

enum StatutConnexion {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum RoleGroupe {
  ADMIN
  MODERATEUR
  MEMBRE
}

enum VisibiliteGroupe {
  PUBLIC
  PRIVE
  SECRET
}

enum PostStatus {
  PUBLIE
  PLANIFIE
  BROUILLON
}

enum StatutSignalement {
  EN_ATTENTE
  EN_COURS
  RESOLU
  REJETE
}

enum TypeSignalement {
  POST
  COMMENTAIRE
  MEMBRE
  GROUPE
}

enum StatutParticipation {
  INSCRIT
  INTERESSE
  ANNULE
}

model Post {
  id           String      @id @default(cuid())
  auteurId     String
  contenu      String
  imageUrl     String?
  images       String[]
  videoUrl     String?
  lienUrl      String?
  lienTitre    String?
  lienDescription String?
  lienImage    String?
  documentUrl  String?
  documentNom  String?
  format       FormatPost  @default(TEXTE)
  hashtags     String[]
  epingle      Boolean     @default(false)
  isAnnonce    Boolean     @default(false)
  status       PostStatus  @default(PUBLIE)
  scheduledAt  DateTime?
  groupeId     String?
  // ─── Partage / repost
  partageDeId  String?
  commentairePartage String?
  // ─── Relations
  auteur       User        @relation(fields: [auteurId], references: [id])
  groupe       Groupe?     @relation(fields: [groupeId], references: [id])
  partageDe    Post?       @relation("Partage", fields: [partageDeId], references: [id], onDelete: SetNull)
  partages     Post[]      @relation("Partage")
  mentions     Mention[]
  commentaires Commentaire[]
  likes        Like[]
  reactions    Reaction[]
  sauvegardes  PostSauvegarde[]
  signalements Signalement[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([auteurId, createdAt])
  @@index([groupeId, createdAt])
  @@index([partageDeId])
  @@index([status, scheduledAt])
}

model Commentaire {
  id           String        @id @default(cuid())
  postId       String
  auteurId     String
  contenu      String
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  auteur       User          @relation(fields: [auteurId], references: [id])
  mentions     Mention[]
  signalements Signalement[]
  createdAt    DateTime      @default(now())

  @@index([postId, createdAt])
}

model Mention {
  id              String       @id @default(cuid())
  userId          String
  postId          String?
  commentaireId   String?
  mentionneurId   String
  user            User         @relation("MentionsConcernees", fields: [userId], references: [id])
  mentionneur     User         @relation("MentionsEmises", fields: [mentionneurId], references: [id])
  post            Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentaire     Commentaire? @relation(fields: [commentaireId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([userId])
  @@index([postId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String?
  messageId String?
  userId    String
  type      TypeReaction
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  message   Message?     @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@unique([messageId, userId])
}

model PostSauvegarde {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ─── Connexions & Abonnements ────────────────────────────────────

model Connexion {
  id            String          @id @default(cuid())
  demandeurId   String
  destinataireId String
  statut        StatutConnexion @default(EN_ATTENTE)
  demandeur     User            @relation("Demandeur", fields: [demandeurId], references: [id])
  destinataire  User            @relation("Destinataire", fields: [destinataireId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([demandeurId, destinataireId])
}

model Abonnement {
  id        String   @id @default(cuid())
  abonneId  String
  suiviId   String
  abonne    User     @relation("Abonne", fields: [abonneId], references: [id])
  suivi     User     @relation("Suivi", fields: [suiviId], references: [id])
  createdAt DateTime @default(now())

  @@unique([abonneId, suiviId])
}

// ─── Groupes de discussion ───────────────────────────────────────

model Groupe {
  id          String             @id @default(cuid())
  nom         String
  slug        String             @unique
  description String?
  imageUrl    String?
  visibilite  VisibiliteGroupe   @default(PUBLIC)
  regles      String?
  membres     MembreGroupe[]
  posts       Post[]
  evenements  Evenement[]
  questions   QuestionAdhesion[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MembreGroupe {
  id        String            @id @default(cuid())
  groupeId  String
  userId    String
  role      RoleGroupe        @default(MEMBRE)
  approuve  Boolean           @default(true)
  groupe    Groupe            @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])
  reponses  ReponseAdhesion[]
  createdAt DateTime          @default(now())

  @@unique([groupeId, userId])
}

// ─── Questions & réponses d'adhésion ─────────────────────────────

model QuestionAdhesion {
  id        String            @id @default(cuid())
  groupeId  String
  texte     String
  ordre     Int               @default(0)
  groupe    Groupe            @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  reponses  ReponseAdhesion[]

  @@index([groupeId, ordre])
}

model ReponseAdhesion {
  id           String           @id @default(cuid())
  membreId     String
  questionId   String
  reponse      String
  membre       MembreGroupe     @relation(fields: [membreId], references: [id], onDelete: Cascade)
  question     QuestionAdhesion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([membreId, questionId])
}

// ─── Événements communautaires ───────────────────────────────────

model Evenement {
  id            String          @id @default(cuid())
  titre         String
  description   String
  imageUrl      String?
  lieu          String?
  dateDebut     DateTime
  dateFin       DateTime?
  createurId    String
  groupeId      String?
  maxParticipants Int?
  createur      User            @relation("CreateurEvenement", fields: [createurId], references: [id])
  groupe        Groupe?         @relation(fields: [groupeId], references: [id])
  participations ParticipationEvenement[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ParticipationEvenement {
  id          String              @id @default(cuid())
  evenementId String
  userId      String
  statut      StatutParticipation @default(INSCRIT)
  evenement   Evenement           @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id])
  createdAt   DateTime            @default(now())

  @@unique([evenementId, userId])
}

// ─── Modération & Sécurité ───────────────────────────────────────

model Signalement {
  id            String           @id @default(cuid())
  signaleurId   String
  signaleUserId String?
  postId        String?
  commentaireId String?
  type          TypeSignalement
  raison        String
  description   String?
  statut        StatutSignalement @default(EN_ATTENTE)
  noteAdmin     String?
  signaleur     User             @relation("Signaleur", fields: [signaleurId], references: [id])
  signaleUser   User?            @relation("Signale", fields: [signaleUserId], references: [id])
  post          Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  commentaire   Commentaire?     @relation(fields: [commentaireId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Blocage {
  id         String   @id @default(cuid())
  bloqueurId String
  bloqueId   String
  bloqueur   User     @relation("Bloqueur", fields: [bloqueurId], references: [id])
  bloque     User     @relation("Bloque", fields: [bloqueId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([bloqueurId, bloqueId])
}

model ProfilDetail {
  id                    String   @id @default(cuid())
  userId                String   @unique
  ville                 String?
  languesParlees        String[]
  // Champs professionnels (visibles uniquement si PROFESSIONNEL_SANTE)
  specialite            String?
  numeroOrdre           String?  // masqué publiquement, visible par admin
  joursDisponibilite    String[] // ex: ["Lundi", "Mardi"]
  horairesDisponibilite String?  // ex: "09:00 - 17:00"
  languesConsultation   String[]
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt             DateTime @updatedAt
}

model Story {
  id          String          @id @default(cuid())
  auteurId    String
  type        StoryType
  contenu     String?         // texte ou URL média
  mediaUrl    String?         // URL Cloudinary
  couleurFond String?         // hex pour stories textuelles
  visibilite  StoryVisibilite @default(PUBLIC)
  viewers     String[]        // IDs des utilisateurs ayant visionné
  auteur      User            @relation(fields: [auteurId], references: [id])
  createdAt   DateTime        @default(now())
  expiresAt   DateTime

  @@index([auteurId])
  @@index([expiresAt])
}
