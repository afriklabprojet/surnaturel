// Schéma Prisma — Institut de Bien-Être « Le Surnaturel de Dieu »

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
  SAGE_FEMME
  ACCOMPAGNATEUR_MEDICAL
}

enum CategorieSoin {
  HAMMAM
  GOMMAGE
  AMINCISSANT
  VISAGE
  POST_ACCOUCHEMENT
  CONSEIL_ESTHETIQUE
  SAGE_FEMME
}

enum StatutRDV {
  EN_ATTENTE
  CONFIRME
  ANNULE
  TERMINE
}

enum StatutCommande {
  EN_ATTENTE
  PAIEMENT_EN_COURS
  PAYEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
}

enum VerificationStatus {
  AUCUNE
  MEMBRE_VERIFIE
  PROFESSIONNEL_SANTE
}

enum StoryType {
  TEXTE
  IMAGE
  VIDEO
}

enum StoryVisibilite {
  PUBLIC
  CONNEXIONS
}

enum IntentionRencontre {
  AMITIE
  RELATION_SERIEUSE
  MARIAGE
}

enum TypeLike {
  LIKE
  SUPER_LIKE
  PASS
}

// ─── Modèles ─────────────────────────────────────────────────────

model User {
  id                      String                         @id @default(cuid())
  email                   String                         @unique
  passwordHash            String?
  nom                     String
  prenom                  String
  name                    String? // nom complet (NextAuth)
  telephone               String?
  adresse                 String?
  role                    Role                           @default(CLIENT)
  photoUrl                String?
  image                   String? // avatar (NextAuth)
  ville                   String?
  codeParrainage          String?                        @unique
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  // ─── Profil étendu réseau social
  bio                     String?
  centresInteret          String[]
  couvertureUrl           String?
  profilPublic            Boolean                        @default(true)
  pseudo                  String?                        @unique
  localisation            String?
  statutProfil            StatutProfil                   @default(ACTIF)
  // ─── Préférences notifications
  notifLikes              Boolean                        @default(true)
  notifCommentaires       Boolean                        @default(true)
  notifConnexions         Boolean                        @default(true)
  notifMessages           Boolean                        @default(true)
  notifEvenements         Boolean                        @default(true)
  notifGroupes            Boolean                        @default(true)
  notifNewsletter         Boolean                        @default(true)
  // ─── Relations existantes
  rendezVous              RendezVous[]
  commandes               Commande[]
  messages                Message[]
  dossierMedical          DossierMedical?
  notifications           Notification[]
  pointsFidelite          PointsFidelite?
  favoris                 Favori[]
  parrainagesParrain      Parrainage[]                   @relation("Parrain")
  parrainagesFilleul      Parrainage[]                   @relation("Filleul")
  avis                    Avis[]
  // ─── Relations réseau social
  posts                   Post[]
  commentaires            Commentaire[]
  reactions               Reaction[]
  postsSauvegardes        PostSauvegarde[]
  connexionsEnvoyees      Connexion[]                    @relation("Demandeur")
  connexionsRecues        Connexion[]                    @relation("Destinataire")
  abonnements             Abonnement[]                   @relation("Abonne")
  abonnes                 Abonnement[]                   @relation("Suivi")
  groupesMembres          MembreGroupe[]
  evenementsCreateur      Evenement[]                    @relation("CreateurEvenement")
  participations          ParticipationEvenement[]
  signalementsEmis        Signalement[]                  @relation("Signaleur")
  signalementsRecus       Signalement[]                  @relation("Signale")
  blocagesEmis            Blocage[]                      @relation("Bloqueur")
  blocagesRecus           Blocage[]                      @relation("Bloque")
  mentionsConcernees      Mention[]                      @relation("MentionsConcernees")
  mentionsEmises          Mention[]                      @relation("MentionsEmises")
  stories                 Story[]
  conversationsA          Conversation[]                 @relation("ConvA")
  conversationsB          Conversation[]                 @relation("ConvB")
  verificationStatus      VerificationStatus             @default(AUCUNE)
  profilDetail            ProfilDetail?
  // ─── Reset mot de passe
  resetToken              String?                        @unique
  resetTokenExpiry        DateTime?
  // ─── Vérification email
  emailVerifie            Boolean                        @default(false)
  emailVerifToken         String?                        @unique
  emailVerifExpiry        DateTime?
  // ─── Onboarding email sequence
  onboardingStep          Int                            @default(0) // 0=welcome, 1=soins, 2=boutique, 3=communauté
  lastOnboardingEmail     DateTime?
  derniereVueAt           DateTime? // présence en ligne
  dateNaissance           DateTime? // pour filtrage par âge (rencontres)
  // ─── Rencontres
  rencontrePreference     RencontrePreference?
  likesEnvoyes            RencontreLike[]                @relation("LikesEnvoyes")
  likesRecus              RencontreLike[]                @relation("LikesRecus")
  matchesA                RencontreMatch[]               @relation("MatchesA")
  matchesB                RencontreMatch[]               @relation("MatchesB")
  // ─── Messages médicaux (table séparée)
  messagesMedicauxEnvoyes MessageMedical[]               @relation("MessagesMedicauxEnvoyes")
  messagesMedicauxRecus   MessageMedical[]               @relation("MessagesMedicauxRecus")
  // ─── Push subscriptions
  pushSubscriptions       PushSubscription[]
  // ─── Échanges de récompenses fidélité
  echangesRecompenses     EchangeRecompense[]
  // ─── Utilisations de codes promo
  utilisationsCodePromo   UtilisationCodePromo[]
  // ─── Notes & suivi paramédical
  notesRecues             NotePro[]                      @relation("NoteClient")
  notesEcrites            NotePro[]                      @relation("NoteAuteur")
  questionnaires          QuestionnairePreConsultation[]
  // ─── Abonnements mensuels
  abonnementsMensuels     AbonnementMensuel[]
  // ─── Avis produits
  avisProduits            AvisProduit[]
  // ─── WebAuthn / Passkeys (Face ID, Touch ID)
  webAuthnCredentials     WebAuthnCredential[]
  // ─── 2FA / Two-Factor Authentication
  totpSecret              String? // Encrypted TOTP secret
  totpEnabled             Boolean                        @default(false)
  totpBackupCodes         String[] // Hashed backup codes
  totpVerifiedAt          DateTime? // When 2FA was enabled
  // ─── Session tracking
  authSessions            AuthSession[]
  lastLoginAt             DateTime?
  lastLoginIp             String?
  lastLoginDevice         String?
  // ─── Accès Communauté (abonnement payant ou essai gratuit)
  accesCommuaute          Boolean                        @default(false)
  accesCommuauteExpireAt  DateTime?
  essaiCommuauteUtilise   Boolean                        @default(false)
}

// ─── WebAuthn Credentials (Passkeys) ─────────────────────────────
model WebAuthnCredential {
  id                  String    @id @default(cuid())
  userId              String
  credentialId        String    @unique // Base64url encoded credential ID
  credentialPublicKey Bytes // CBOR encoded public key
  counter             BigInt    @default(0) // Signature counter for replay attack prevention
  transports          String[] // Array of transport hints (usb, nfc, ble, internal)
  deviceName          String? // User-friendly device name
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Auth Sessions (Track active sessions for 2FA/session mgmt) ──
model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  tokenHash        String    @unique // Hash of session token for lookup
  ipAddress        String?
  userAgent        String?
  deviceName       String? // Parsed device name (iPhone 15, Chrome Windows, etc.)
  deviceType       String? // mobile, desktop, tablet
  location         String? // Geo location from IP
  isCurrentSession Boolean   @default(false)
  lastActiveAt     DateTime  @default(now())
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime? // If session was manually revoked
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Push Subscriptions (Web Push API) ───────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String // clé publique
  auth      String // secret d'authentification
  userAgent String? // pour identifier l'appareil
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Soin {
  id                String        @id @default(cuid())
  nom               String
  slug              String        @unique
  description       String
  descriptionLongue String?
  deroulement       String?
  bienfaits         String[]
  etapes            Json? // [{titre, description}]
  prix              Float
  duree             Int // en minutes
  categorie         CategorieSoin
  icon              String? // nom lucide-react ex: "Flame"
  badge             String? // ex: "Populaire", "Nouveau"
  imageUrl          String?
  ordre             Int           @default(0)
  actif             Boolean       @default(true)
  rendezVous        RendezVous[]
  favoris           Favori[]
  avis              Avis[]
  forfaitSoins      ForfaitSoin[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model RendezVous {
  id              String    @id @default(cuid())
  userId          String
  soinId          String
  dateHeure       DateTime
  creneauCle      String? // Format: "soinId_YYYY-MM-DD_HH" pour contrainte unique
  statut          StatutRDV @default(EN_ATTENTE)
  notes           String?
  montantAcompte  Float?
  paiementId      String?
  acomptePaye     Boolean   @default(false)
  telephoneSms    String?
  smsRappelEnvoye Boolean   @default(false)
  emailAvisEnvoye Boolean   @default(false)
  user            User      @relation(fields: [userId], references: [id])
  soin            Soin      @relation(fields: [soinId], references: [id])
  avis            Avis?
  createdAt       DateTime  @default(now())

  // Contrainte unique sur creneauCle (null ignoré = RDV annulés)
  @@unique([creneauCle])
  @@index([soinId, dateHeure])
}

model Produit {
  id                String          @id @default(cuid())
  nom               String
  description       String
  descriptionLongue String?
  prix              Float
  prixPromo         Float?
  stock             Int             @default(0)
  imageUrl          String?
  categorie         String
  actif             Boolean         @default(true)
  lignesCommande    LigneCommande[]
  favoris           Favori[]
  avisProduits      AvisProduit[]
  createdAt         DateTime        @default(now())
}

// ─── Avis Produits ───────────────────────────────────────────────

model AvisProduit {
  id          String   @id @default(cuid())
  userId      String
  produitId   String
  commandeId  String? // Optionnel: lié à une commande pour vérification achat
  note        Int // 1-5 étoiles
  titre       String?
  commentaire String?
  utile       Int      @default(0) // Votes "utile"
  publie      Boolean  @default(true)
  verifie     Boolean  @default(false) // Achat vérifié
  user        User     @relation(fields: [userId], references: [id])
  produit     Produit  @relation(fields: [produitId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, produitId]) // Un seul avis par produit par utilisateur
  @@index([produitId, publie])
  @@index([produitId, createdAt])
}

model Commande {
  id                 String          @id @default(cuid())
  userId             String
  total              Float
  codePromo          String?
  reduction          Float           @default(0)
  fraisLivraison     Float           @default(0)
  zoneLivraison      String?
  nomDestinataire    String?
  adresseLivraison   String?
  telephoneLivraison String?
  statut             StatutCommande  @default(EN_ATTENTE)
  paiementId         String?
  webhookTraite      Boolean         @default(false)
  methodePaiement    String?
  tentativesPaiement Int             @default(0)
  dernierEchecAt     DateTime?
  relanceSmsEnvoyee  Boolean         @default(false)
  user               User            @relation(fields: [userId], references: [id])
  lignes             LigneCommande[]
  createdAt          DateTime        @default(now())

  @@index([statut, dernierEchecAt])
}

model LigneCommande {
  id           String   @id @default(cuid())
  commandeId   String
  produitId    String
  quantite     Int
  prixUnitaire Float
  commande     Commande @relation(fields: [commandeId], references: [id])
  produit      Produit  @relation(fields: [produitId], references: [id])
}

enum MessageType {
  TEXTE
  VOCAL
  MEDIA
  FICHIER
}

// ─── Conversation ────────────────────────────────────────────────
// Remplace le DISTINCT ON $queryRaw : 1 row par conversation, mise à jour sur
// chaque nouveau message. participantAId < participantBId (tri lexicographique).
model Conversation {
  id             String          @id @default(cuid())
  participantAId String
  participantBId String
  lastMessageId  String? // id du dernier message (dénormalisé pour rapidité)
  lastMessageAt  DateTime        @default(now())
  nonLusA        Int             @default(0) // non-lus pour participantA
  nonLusB        Int             @default(0) // non-lus pour participantB
  participantA   User            @relation("ConvA", fields: [participantAId], references: [id])
  participantB   User            @relation("ConvB", fields: [participantBId], references: [id])
  messages       Message[]
  matchRencontre RencontreMatch?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([participantAId, participantBId])
  @@index([participantAId, lastMessageAt])
  @@index([participantBId, lastMessageAt])
}

model Message {
  id              String        @id @default(cuid())
  expediteurId    String
  destinataireId  String
  conversationId  String?
  contenu         String
  type            MessageType   @default(TEXTE)
  dureeSecondes   Int? // durée audio pour VOCAL
  lu              Boolean       @default(false)
  replyToId       String?
  replyTo         Message?      @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         Message[]     @relation("MessageReply")
  reactions       Reaction[]    @relation("MessageReactions")
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  expediteur      User          @relation(fields: [expediteurId], references: [id])
  createdAt       DateTime      @default(now())
  modifie         Boolean       @default(false)
  modifieLeAt     DateTime?
  luLe            DateTime? // horodatage de lecture
  epingle         Boolean       @default(false)
  expiresAt       DateTime? // messages éphémères
  programmeA      DateTime? // message programmé — date d'envoi
  programmeEnvoye Boolean       @default(false) // true quand le cron a envoyé

  @@index([expediteurId, destinataireId])
  @@index([destinataireId, lu]) // conversations: comptage non-lus
  @@index([expediteurId, createdAt]) // conversations: tri par date
  @@index([destinataireId, createdAt]) // historique: pagination
}

// ─── Messages médicaux (table dédiée, totalement isolée) ─────────

model MessageMedical {
  id             String   @id @default(cuid())
  expediteurId   String
  destinataireId String
  contenu        String // TOUJOURS chiffré (AES-256-GCM)
  lu             Boolean  @default(false)
  expediteur     User     @relation("MessagesMedicauxEnvoyes", fields: [expediteurId], references: [id])
  destinataire   User     @relation("MessagesMedicauxRecus", fields: [destinataireId], references: [id])
  createdAt      DateTime @default(now())

  @@index([expediteurId, destinataireId])
  @@index([destinataireId, lu])
  @@index([expediteurId, createdAt])
  @@index([destinataireId, createdAt])
}

model DossierMedical {
  id               String            @id @default(cuid())
  userId           String            @unique
  pathologie       String? // chiffré
  notes            String? // chiffré
  allergies        String? // chiffré
  antecedents      String? // chiffré (chirurgies, maladies passées)
  medicaments      String? // chiffré (traitements en cours)
  groupeSanguin    String?
  contactUrgence   String? // chiffré
  user             User              @relation(fields: [userId], references: [id])
  mesures          MesureSante[]
  documents        DocumentMedical[]
  entrees          EntreeCarnet[]
  suiviSpecialises SuiviSpecialise[]
  updatedAt        DateTime          @updatedAt
}

// ─── Carnet de Santé & Bien-Être ─────────────────────────────────

model EntreeCarnet {
  id                   String         @id @default(cuid())
  dossierId            String
  date                 String // "YYYY-MM-DD" — un seul carnet par jour
  humeur               Int? // 1-5 : 1=très mal, 5=excellente
  energie              Int? // 1-5
  sommeil              Float? // heures dormies (0.0-12.0)
  hydratation          Int? // verres d'eau 0-15
  symptomes            String? // JSON chiffré : ["fatigue","douleur_lombaire",...]
  cycleMenstruel       Boolean        @default(false)
  jourCycle            Int? // n° du jour dans le cycle
  fluxCycle            String? // "leger"|"moyen"|"abondant"|null
  notes                String? // texte libre chiffré (AES-256)
  partageAvecPraticien Boolean        @default(false)
  tags                 String? // JSON : ["post-soin","stress","rdv-sage-femme",...]
  dossier              DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([dossierId, date])
  @@index([dossierId, date])
}

// ─── Mesures de santé / Suivi vital ──────────────────────────────

enum TypeMesure {
  POIDS
  TENSION_ARTERIELLE
  TEMPERATURE
  GLYCEMIE
  TOUR_DE_TAILLE
  FREQUENCE_CARDIAQUE
  AUTRE
}

model MesureSante {
  id          String         @id @default(cuid())
  dossierId   String
  type        TypeMesure
  valeur      String // ex: "75", "12/8", "37.2"
  unite       String // ex: "kg", "mmHg", "°C"
  commentaire String?
  dossier     DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt   DateTime       @default(now())

  @@index([dossierId, type])
  @@index([dossierId, createdAt])
}

// ─── Documents médicaux ──────────────────────────────────────────

enum TypeDocument {
  ORDONNANCE
  ANALYSE
  RADIO_IMAGERIE
  COMPTE_RENDU
  CERTIFICAT
  AUTRE
}

model DocumentMedical {
  id          String         @id @default(cuid())
  dossierId   String
  nom         String
  type        TypeDocument
  fileUrl     String // URL Cloudinary
  taille      Int? // en octets
  description String? // chiffré
  dossier     DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt   DateTime       @default(now())

  @@index([dossierId, type])
  @@index([dossierId, createdAt])
}

model Article {
  id           String   @id @default(cuid())
  titre        String
  slug         String   @unique
  contenu      String
  categorie    String   @default("Bien-être")
  auteur       String   @default("Équipe éditoriale")
  auteurRole   String   @default("Équipe du Surnaturel de Dieu")
  tempsLecture Int      @default(3)
  imageUrl     String?
  publie       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ─── Nouveaux modèles — Améliorations ────────────────────────────

enum NotifType {
  RDV_CONFIRME
  RDV_ANNULE
  COMMANDE_PAYEE
  COMMANDE_EXPEDIEE
  NOUVEAU_MESSAGE
  FIDELITE_POINTS
  FIDELITE_RECOMPENSE
  PARRAINAGE
  // ─── Réseau social
  NOUVEAU_LIKE
  NOUVEAU_COMMENTAIRE
  NOUVELLE_CONNEXION
  DEMANDE_CONNEXION
  MENTION
  INVITATION_GROUPE
  EVENEMENT_RAPPEL
  SIGNALEMENT_TRAITE
  ANNONCE_GROUPE
  REACTION_MESSAGE
}

enum TypeFidelite {
  GAIN_RDV
  GAIN_COMMANDE
  GAIN_PARRAINAGE
  GAIN_AVIS
  DEPOT_RECOMPENSE
}

enum StatutParrainage {
  EN_ATTENTE
  ACTIF
  RECOMPENSE_ACCORDEE
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  titre     String
  message   String
  lu        Boolean   @default(false)
  lien      String?
  sourceId  String?
  compteur  Int       @default(1)
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  // Déduplication : un seul enregistrement par (user, type, sourcePost/Message)
  // NULL sourceId = notifications sans source (RDV, etc.) → pas de dédup (NULLs distincts en PG)
  @@unique([userId, type, sourceId], name: "notif_dedup")
  @@index([userId, lu])
  @@index([userId, createdAt])
}

model PointsFidelite {
  id         String               @id @default(cuid())
  userId     String               @unique
  total      Int                  @default(0)
  user       User                 @relation(fields: [userId], references: [id])
  historique HistoriqueFidelite[]
}

model HistoriqueFidelite {
  id        String         @id @default(cuid())
  pointsId  String
  points    Int
  raison    String
  type      TypeFidelite
  pointsFid PointsFidelite @relation(fields: [pointsId], references: [id])
  createdAt DateTime       @default(now())
}

enum TypeRecompense {
  REDUCTION
  SOIN_GRATUIT
  PRODUIT
  EXPERIENCE
  AUTRE
}

model Recompense {
  id           String              @id @default(cuid())
  nom          String
  description  String
  pointsRequis Int
  type         TypeRecompense
  valeur       Int? // Pourcentage réduction ou valeur en euros
  imageUrl     String?
  stock        Int? // null = illimité
  actif        Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  echanges     EchangeRecompense[]
}

model EchangeRecompense {
  id             String     @id @default(cuid())
  userId         String
  recompenseId   String
  pointsUtilises Int
  statut         String     @default("EN_COURS") // EN_COURS, UTILISE, EXPIRE
  codeUnique     String     @unique
  dateExpiration DateTime?
  user           User       @relation(fields: [userId], references: [id])
  recompense     Recompense @relation(fields: [recompenseId], references: [id])
  createdAt      DateTime   @default(now())
}

// ─── Galerie Avant/Après ──────────────────────────────────────────
model GaleriePhoto {
  id                 String   @id @default(cuid())
  titre              String
  description        String?
  soinNom            String // Nom du soin (pas de relation FK pour flexibilité)
  imageAvantUrl      String
  imageApresUrl      String
  consentementClient Boolean  @default(false)
  approuve           Boolean  @default(false)
  ordre              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Témoignages Vidéo ────────────────────────────────────────────
model TemoignageVideo {
  id                 String   @id @default(cuid())
  titre              String
  clientNom          String // Prénom de la cliente
  soinNom            String? // Soin concerné (optionnel)
  videoUrl           String // URL YouTube, Vimeo, etc.
  thumbnailUrl       String? // Miniature personnalisée
  duree              Int? // Durée en secondes
  description        String?
  consentementClient Boolean  @default(false)
  approuve           Boolean  @default(false)
  vedette            Boolean  @default(false) // Afficher en premier plan
  ordre              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Newsletter ───────────────────────────────────────────────────
model Newsletter {
  id              String    @id @default(cuid())
  sujet           String
  contenu         String // HTML du contenu
  type            String    @default("HEBDOMADAIRE") // HEBDOMADAIRE, PROMO, EVENEMENT
  nbDestinataires Int       @default(0)
  nbOuvertures    Int       @default(0)
  nbClics         Int       @default(0)
  envoye          Boolean   @default(false)
  dateEnvoi       DateTime?
  createdAt       DateTime  @default(now())
}

// Abonnés newsletter (visiteurs non connectés)
model AbonneNewsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Favori {
  id        String   @id @default(cuid())
  userId    String
  soinId    String?
  produitId String?
  user      User     @relation(fields: [userId], references: [id])
  soin      Soin?    @relation(fields: [soinId], references: [id])
  produit   Produit? @relation(fields: [produitId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, soinId])
  @@unique([userId, produitId])
}

model Parrainage {
  id        String           @id @default(cuid())
  parrainId String
  filleulId String?
  code      String           @unique
  statut    StatutParrainage @default(EN_ATTENTE)
  parrain   User             @relation("Parrain", fields: [parrainId], references: [id])
  filleul   User?            @relation("Filleul", fields: [filleulId], references: [id])
  createdAt DateTime         @default(now())
}

model Avis {
  id          String     @id @default(cuid())
  userId      String
  rdvId       String     @unique
  soinId      String
  note        Int
  commentaire String?
  publie      Boolean    @default(false)
  user        User       @relation(fields: [userId], references: [id])
  rdv         RendezVous @relation(fields: [rdvId], references: [id])
  soin        Soin       @relation(fields: [soinId], references: [id])
  createdAt   DateTime   @default(now())
}

// ─── Codes promo — Campagnes marketing AVANCÉ ────────────────────

enum TypeReduction {
  POURCENTAGE
  MONTANT_FIXE
}

model CodePromo {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  description        String?
  type               TypeReduction          @default(POURCENTAGE)
  valeur             Float // Pourcentage (1-100) ou montant fixe en FCFA
  montantMin         Float? // Montant minimum du panier pour appliquer
  montantMax         Float? // Réduction max applicable (pour pourcentage)
  usageMax           Int? // Nombre max d'utilisations global (null = illimité)
  usageActuel        Int                    @default(0)
  usageParUser       Int                    @default(1) // Combien de fois un même user peut l'utiliser
  debutValidite      DateTime?
  finValidite        DateTime?
  premiereCommande   Boolean                @default(false) // Valide uniquement pour la 1ère commande
  nouveauxClients    Boolean                @default(false) // Clients inscrits < 30 jours
  categoriesProduits String[] // IDs catégories ciblées (vide = toutes)
  produitsExclus     String[] // IDs produits exclus
  cumulable          Boolean                @default(false) // Peut être combiné avec d'autres codes
  actif              Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  // Tracking des utilisations
  utilisations       UtilisationCodePromo[]

  // Compatibilité ancienne version
  pourcentage Int? // DEPRECATED - utiliser valeur
}

model UtilisationCodePromo {
  id            String    @id @default(cuid())
  codePromoId   String
  userId        String
  commandeId    String?
  montantReduit Float // Montant de la réduction appliquée
  codePromo     CodePromo @relation(fields: [codePromoId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([codePromoId])
  @@index([userId])
}

// ─── Réseau social — Communauté ──────────────────────────────────

enum StatutProfil {
  ACTIF
  EN_PAUSE
  PRO_SANTE
}

// TypeReaction remplacé par String pour supporter tout emoji

enum FormatPost {
  TEXTE
  IMAGE
  VIDEO
  LIEN
  DOCUMENT
}

enum StatutConnexion {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum RoleGroupe {
  ADMIN
  MODERATEUR
  MEMBRE
}

enum VisibiliteGroupe {
  PUBLIC
  PRIVE
  SECRET
}

enum PostStatus {
  PUBLIE
  PLANIFIE
  BROUILLON
  EN_ATTENTE_MODERATION
}

enum TypeSanction {
  AVERTISSEMENT
  MUTE
  BAN
  KICK
}

enum CategorieGroupe {
  SANTE
  BIEN_ETRE
  SPORT
  EDUCATION
  BUSINESS
  FAMILLE
  CULTURE
  SPIRITUALITE
  AUTRE
}

enum StatutSignalement {
  EN_ATTENTE
  EN_COURS
  RESOLU
  REJETE
}

enum TypeSignalement {
  POST
  COMMENTAIRE
  MEMBRE
  GROUPE
}

enum StatutParticipation {
  INSCRIT
  INTERESSE
  ANNULE
}

model Post {
  id                 String           @id @default(cuid())
  auteurId           String
  contenu            String
  imageUrl           String?
  images             String[]
  videoUrl           String?
  lienUrl            String?
  lienTitre          String?
  lienDescription    String?
  lienImage          String?
  documentUrl        String?
  documentNom        String?
  gifUrl             String?
  masque             Boolean          @default(false)
  format             FormatPost       @default(TEXTE)
  hashtags           String[]
  epingle            Boolean          @default(false)
  isAnnonce          Boolean          @default(false)
  status             PostStatus       @default(PUBLIE)
  scheduledAt        DateTime?
  groupeId           String?
  // ─── Partage / repost
  partageDeId        String?
  commentairePartage String?
  // ─── Relations
  auteur             User             @relation(fields: [auteurId], references: [id])
  groupe             Groupe?          @relation(fields: [groupeId], references: [id])
  partageDe          Post?            @relation("Partage", fields: [partageDeId], references: [id], onDelete: SetNull)
  partages           Post[]           @relation("Partage")
  mentions           Mention[]
  commentaires       Commentaire[]
  reactions          Reaction[]
  sauvegardes        PostSauvegarde[]
  signalements       Signalement[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([auteurId, createdAt])
  @@index([groupeId, createdAt])
  @@index([partageDeId])
  @@index([status, scheduledAt])
}

model Commentaire {
  id           String        @id @default(cuid())
  postId       String
  auteurId     String
  contenu      String
  masque       Boolean       @default(false)
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  auteur       User          @relation(fields: [auteurId], references: [id])
  mentions     Mention[]
  signalements Signalement[]
  createdAt    DateTime      @default(now())

  @@index([postId, createdAt])
}

model Mention {
  id            String       @id @default(cuid())
  userId        String
  postId        String?
  commentaireId String?
  mentionneurId String
  user          User         @relation("MentionsConcernees", fields: [userId], references: [id])
  mentionneur   User         @relation("MentionsEmises", fields: [mentionneurId], references: [id])
  post          Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentaire   Commentaire? @relation(fields: [commentaireId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@index([userId])
  @@index([postId])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String?
  messageId String?
  userId    String
  type      String // emoji libre ou ancien type (JAIME, SOUTIEN, ...)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  message   Message? @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@unique([messageId, userId])
}

model PostSauvegarde {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ─── Connexions & Abonnements ────────────────────────────────────

model Connexion {
  id             String          @id @default(cuid())
  demandeurId    String
  destinataireId String
  statut         StatutConnexion @default(EN_ATTENTE)
  demandeur      User            @relation("Demandeur", fields: [demandeurId], references: [id])
  destinataire   User            @relation("Destinataire", fields: [destinataireId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([demandeurId, destinataireId])
}

model Abonnement {
  id        String   @id @default(cuid())
  abonneId  String
  suiviId   String
  abonne    User     @relation("Abonne", fields: [abonneId], references: [id])
  suivi     User     @relation("Suivi", fields: [suiviId], references: [id])
  createdAt DateTime @default(now())

  @@unique([abonneId, suiviId])
}

// ─── Groupes de discussion ───────────────────────────────────────

model Groupe {
  id                    String              @id @default(cuid())
  nom                   String
  slug                  String              @unique
  description           String?
  imageUrl              String?
  visibilite            VisibiliteGroupe    @default(PUBLIC)
  regles                String?
  categorie             CategorieGroupe     @default(AUTRE)
  approvalRequired      Boolean             @default(false) // Modération des publications
  inviteCode            String?             @unique
  tags                  String[] // Mots-clés / tags du groupe
  archivee              Boolean             @default(false)
  // ── Paramètres granulaires
  quiPeutPublier        String              @default("TOUS") // TOUS | ADMINS_SEULEMENT
  quiPeutCommenter      String              @default("TOUS") // TOUS | MEMBRES_SEULEMENT
  reactionsActivees     Boolean             @default(true)
  invitationsParMembres Boolean             @default(true)
  suggestionsActivees   Boolean             @default(true)
  partagesExternes      Boolean             @default(true)
  slowModeMinutes       Int                 @default(0) // 0 = désactivé
  badgesActifs          Boolean             @default(true)
  // ── Sous-groupe
  parentGroupeId        String?
  parentGroupe          Groupe?             @relation("SousGroupes", fields: [parentGroupeId], references: [id], onDelete: SetNull)
  sousGroupes           Groupe[]            @relation("SousGroupes")
  // ── Relations
  membres               MembreGroupe[]
  posts                 Post[]
  evenements            Evenement[]
  questions             QuestionAdhesion[]
  sondages              Sondage[]
  sanctions             Sanction[]
  motsBloques           MotBloque[]
  reglesGroupe          RegleGroupe[]
  badgesGroupe          BadgeGroupe[]
  journalModeration     JournalModeration[]
  notifPrefsGroupes     NotifPrefGroupe[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model MembreGroupe {
  id         String            @id @default(cuid())
  groupeId   String
  userId     String
  role       RoleGroupe        @default(MEMBRE)
  approuve   Boolean           @default(true)
  banni      Boolean           @default(false)
  badge      String? // Badge spécial : "contributeur", "veteran", "expert"…
  mutedUntil DateTime? // Muté jusqu'à cette date
  invitePar  String? // userId de qui a invité
  groupe     Groupe            @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id])
  reponses   ReponseAdhesion[]
  createdAt  DateTime          @default(now())

  @@unique([groupeId, userId])
}

// ─── Questions & réponses d'adhésion ─────────────────────────────

model QuestionAdhesion {
  id       String            @id @default(cuid())
  groupeId String
  texte    String
  ordre    Int               @default(0)
  groupe   Groupe            @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  reponses ReponseAdhesion[]

  @@index([groupeId, ordre])
}

model ReponseAdhesion {
  id         String           @id @default(cuid())
  membreId   String
  questionId String
  reponse    String
  membre     MembreGroupe     @relation(fields: [membreId], references: [id], onDelete: Cascade)
  question   QuestionAdhesion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([membreId, questionId])
}

// ─── Sondages ────────────────────────────────────────────────────

model Sondage {
  id         String          @id @default(cuid())
  groupeId   String
  createurId String
  question   String
  multiChoix Boolean         @default(false)
  anonyme    Boolean         @default(false)
  expireAt   DateTime?
  groupe     Groupe          @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  options    OptionSondage[]
  createdAt  DateTime        @default(now())

  @@index([groupeId, createdAt])
}

model OptionSondage {
  id        String        @id @default(cuid())
  sondageId String
  texte     String
  ordre     Int           @default(0)
  sondage   Sondage       @relation(fields: [sondageId], references: [id], onDelete: Cascade)
  votes     VoteSondage[]
}

model VoteSondage {
  id        String        @id @default(cuid())
  optionId  String
  userId    String
  option    OptionSondage @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([optionId, userId])
}

// ─── Modération : Sanctions & Mots bloqués ───────────────────────

model Sanction {
  id           String       @id @default(cuid())
  groupeId     String
  userId       String // Membre sanctionné
  moderateurId String // Qui a sanctionné
  type         TypeSanction
  raison       String
  duree        Int? // En heures (null = permanent)
  dateDebut    DateTime     @default(now())
  dateFin      DateTime?
  actif        Boolean      @default(true)
  groupe       Groupe       @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@index([groupeId, userId])
  @@index([userId, actif])
}

model MotBloque {
  id        String   @id @default(cuid())
  groupeId  String
  mot       String
  action    String   @default("supprimer") // "supprimer" | "signaler"
  groupe    Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([groupeId, mot])
}

// ─── Événements communautaires ───────────────────────────────────

model Evenement {
  id              String                   @id @default(cuid())
  titre           String
  description     String
  imageUrl        String?
  lieu            String?
  lienEnLigne     String? // Lien visio (Zoom, Meet, etc.)
  dateDebut       DateTime
  dateFin         DateTime?
  createurId      String
  groupeId        String?
  maxParticipants Int?
  createur        User                     @relation("CreateurEvenement", fields: [createurId], references: [id])
  groupe          Groupe?                  @relation(fields: [groupeId], references: [id])
  participations  ParticipationEvenement[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model ParticipationEvenement {
  id          String              @id @default(cuid())
  evenementId String
  userId      String
  statut      StatutParticipation @default(INSCRIT)
  evenement   Evenement           @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id])
  createdAt   DateTime            @default(now())

  @@unique([evenementId, userId])
}

// ─── Modération & Sécurité ───────────────────────────────────────

model Signalement {
  id            String            @id @default(cuid())
  signaleurId   String
  signaleUserId String?
  postId        String?
  commentaireId String?
  type          TypeSignalement
  raison        String
  description   String?
  statut        StatutSignalement @default(EN_ATTENTE)
  noteAdmin     String?
  signaleur     User              @relation("Signaleur", fields: [signaleurId], references: [id])
  signaleUser   User?             @relation("Signale", fields: [signaleUserId], references: [id])
  post          Post?             @relation(fields: [postId], references: [id], onDelete: SetNull)
  commentaire   Commentaire?      @relation(fields: [commentaireId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Blocage {
  id         String   @id @default(cuid())
  bloqueurId String
  bloqueId   String
  bloqueur   User     @relation("Bloqueur", fields: [bloqueurId], references: [id])
  bloque     User     @relation("Bloque", fields: [bloqueId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([bloqueurId, bloqueId])
}

model ProfilDetail {
  id                    String   @id @default(cuid())
  userId                String   @unique
  ville                 String?
  languesParlees        String[]
  // Champs professionnels (visibles uniquement si PROFESSIONNEL_SANTE)
  specialite            String?
  numeroOrdre           String? // masqué publiquement, visible par admin
  joursDisponibilite    String[] // ex: ["Lundi", "Mardi"]
  horairesDisponibilite String? // ex: "09:00 - 17:00"
  languesConsultation   String[]
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt             DateTime @updatedAt
}

model Story {
  id          String          @id @default(cuid())
  auteurId    String
  type        StoryType
  contenu     String? // texte ou URL média
  mediaUrl    String? // URL Cloudinary
  couleurFond String? // hex pour stories textuelles
  visibilite  StoryVisibilite @default(PUBLIC)
  viewers     String[] // IDs des utilisateurs ayant visionné
  auteur      User            @relation(fields: [auteurId], references: [id])
  createdAt   DateTime        @default(now())
  expiresAt   DateTime

  @@index([auteurId])
  @@index([expiresAt])
}

// ─── Règles du groupe ────────────────────────────────────────────

model RegleGroupe {
  id        String   @id @default(cuid())
  groupeId  String
  titre     String
  contenu   String
  ordre     Int      @default(0)
  groupe    Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([groupeId, ordre])
}

// ─── Badges de groupe ────────────────────────────────────────────

model BadgeGroupe {
  id          String   @id @default(cuid())
  groupeId    String
  nom         String
  description String?
  icone       String? // emoji ou URL
  automatique Boolean  @default(false)
  critere     String? // ex: "posts>=10", "membre>=30j", "veteran>=90j"
  groupe      Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([groupeId, nom])
}

// ─── Journal de modération ───────────────────────────────────────

model JournalModeration {
  id             String   @id @default(cuid())
  groupeId       String
  moderateurId   String
  action         String // ex: "BAN", "KICK", "DELETE_POST", "DELETE_COMMENT", "HIDE_COMMENT", "MUTE", "ROLE_CHANGE", "APPROVE_POST"
  cibleUserId    String?
  ciblePostId    String?
  cibleCommentId String?
  details        String?
  groupe         Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([groupeId, createdAt])
}

// ─── Préférences de notification par groupe ──────────────────────

model NotifPrefGroupe {
  id        String   @id @default(cuid())
  groupeId  String
  userId    String
  niveau    String   @default("TOUTES") // TOUTES | AMIS_SEULEMENT | ANNONCES_SEULEMENT | AUCUNE
  groupe    Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupeId, userId])
}

// ─── Forfaits / Packs de soins ───────────────────────────────────

model Forfait {
  id          String        @id @default(cuid())
  slug        String        @unique
  nom         String
  description String
  prixTotal   Float
  prixForfait Float
  economie    Float
  badge       String?
  actif       Boolean       @default(true)
  ordre       Int           @default(0)
  soins       ForfaitSoin[]
  createdAt   DateTime      @default(now())
}

model ForfaitSoin {
  id        String  @id @default(cuid())
  forfaitId String
  soinId    String
  forfait   Forfait @relation(fields: [forfaitId], references: [id], onDelete: Cascade)
  soin      Soin    @relation(fields: [soinId], references: [id])

  @@unique([forfaitId, soinId])
}

// ─── Équipe / Membres du personnel ───────────────────────────────

model MembreEquipe {
  id          String   @id @default(cuid())
  nom         String
  role        String
  description String
  photoUrl    String?
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── FAQ ─────────────────────────────────────────────────────────

model Faq {
  id        String   @id @default(cuid())
  question  String
  reponse   String
  categorie String   @default("soins") // soins, sage-femme, general
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Configuration de l'application ──────────────────────────────

model AppConfig {
  id     String @id @default(cuid())
  cle    String @unique
  valeur String // JSON stringifié
}

// ─── Branding dynamique (White-Label) ────────────────────────────

model BrandingSettings {
  id       String  @id @default(cuid())
  tenantId String? @unique // Multi-tenant ready (null = global)

  // Identité
  appName    String  @default("Le Surnaturel de Dieu")
  logoLight  String? // URL logo pour fond clair
  logoDark   String? // URL logo pour fond sombre
  favicon    String? // URL favicon
  loaderLogo String? // Logo pour écran de chargement

  // Palette de couleurs
  primaryColor      String @default("#2D7A1F")
  primaryDarkColor  String @default("#1A5C10")
  primaryLightColor String @default("#E8F5E3")
  secondaryColor    String @default("#E8F5E3")
  accentColor       String @default("#9A7B22")
  accentLightColor  String @default("#F5EDD6")
  backgroundColor   String @default("#FAFAF7")
  foregroundColor   String @default("#1C1C1C")
  cardColor         String @default("#FFFFFF")
  borderColor       String @default("#E8E4DC")
  dangerColor       String @default("#DC2626")
  successColor      String @default("#16A34A")

  // Typographie
  fontFamily  String @default("Jost")
  fontHeading String @default("Cormorant Garamond")

  // UI
  buttonRadius String @default("md") // sm, md, lg, full
  sidebarTheme String @default("light") // light, dark

  // Page de connexion
  loginBackground String? // Image de fond
  loginTitle      String? // Titre personnalisé
  loginSubtitle   String? // Sous-titre personnalisé
  loginLogoSize   String  @default("md") // sm, md, lg

  // Email branding
  emailLogoUrl      String?
  emailPrimaryColor String  @default("#2D7A1F")
  emailFooterText   String?

  // Presets et métadonnées
  presetName String? // Nom du preset si utilisé
  customCss  String? // CSS personnalisé (injection)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Notes Sage-Femme ────────────────────────────────────────────

model NotePro {
  id             String   @id @default(cuid())
  clientId       String
  auteurId       String
  contenu        String
  type           String   @default("GENERALE") // GENERALE, SUIVI, ALERTE
  partagePatient Boolean  @default(false) // visible par le patient dans son espace
  client         User     @relation("NoteClient", fields: [clientId], references: [id], onDelete: Cascade)
  auteur         User     @relation("NoteAuteur", fields: [auteurId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, partagePatient])
}

// ─── Abonnements Mensuels ────────────────────────────────────────

enum StatutAbonnementMensuel {
  ACTIF
  EN_PAUSE
  ANNULE
  EXPIRE
}

enum FrequenceAbonnement {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
}

// Définition des formules d'abonnement
model FormuleAbonnement {
  id             String              @id @default(cuid())
  nom            String
  slug           String              @unique
  description    String
  prixMensuel    Float
  nbSoinsParMois Int // Nombre de soins inclus par mois
  soinsInclus    String[] // IDs des soins autorisés (vide = tous)
  avantages      String[] // Liste des avantages
  populaire      Boolean             @default(false)
  actif          Boolean             @default(true)
  ordre          Int                 @default(0)
  abonnements    AbonnementMensuel[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Abonnement d'un client
model AbonnementMensuel {
  id                   String                  @id @default(cuid())
  userId               String
  formuleId            String
  statut               StatutAbonnementMensuel @default(ACTIF)
  frequence            FrequenceAbonnement     @default(MENSUEL)
  dateDebut            DateTime
  dateFin              DateTime?
  dateProchainPaiement DateTime
  // Compteurs du mois en cours
  soinsRestantsMois    Int
  moisEnCours          DateTime                @default(now())
  // Paiement automatique
  moyenPaiement        String? // mobile_money, carte, etc.
  referencePaiement    String? // ID pour paiement récurrent
  // Relations
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  formule              FormuleAbonnement       @relation(fields: [formuleId], references: [id])
  paiements            PaiementAbonnement[]
  utilisations         UtilisationAbonnement[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([userId])
  @@index([statut])
}

// Historique des paiements d'abonnement
model PaiementAbonnement {
  id            String            @id @default(cuid())
  abonnementId  String
  montant       Float
  statut        String            @default("EN_ATTENTE") // EN_ATTENTE, PAYE, ECHEC
  moisConcerne  DateTime // Mois couvert par ce paiement
  transactionId String? // ID transaction Jeko
  erreur        String?
  abonnement    AbonnementMensuel @relation(fields: [abonnementId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())

  @@index([abonnementId])
}

// Utilisation des soins de l'abonnement
model UtilisationAbonnement {
  id              String            @id @default(cuid())
  abonnementId    String
  rdvId           String?           @unique // Lié à un RDV
  soinId          String
  dateUtilisation DateTime          @default(now())
  abonnement      AbonnementMensuel @relation(fields: [abonnementId], references: [id], onDelete: Cascade)

  @@index([abonnementId])
}

// ─── Module Rencontres ───────────────────────────────────────────

model RencontrePreference {
  id         String             @id @default(cuid())
  userId     String             @unique
  intention  IntentionRencontre @default(RELATION_SERIEUSE)
  ageMin     Int                @default(18)
  ageMax     Int                @default(50)
  distanceKm Int                @default(50)
  actif      Boolean            @default(true)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt  DateTime           @updatedAt
}

model RencontreLike {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  type       TypeLike @default(LIKE)
  fromUser   User     @relation("LikesEnvoyes", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("LikesRecus", fields: [toUserId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
}

model RencontreMatch {
  id             String        @id @default(cuid())
  userAId        String
  userBId        String
  conversationId String?       @unique
  actif          Boolean       @default(true)
  userA          User          @relation("MatchesA", fields: [userAId], references: [id], onDelete: Cascade)
  userB          User          @relation("MatchesB", fields: [userBId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  createdAt      DateTime      @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ─── Suivi Spécialisé Sage-Femme ─────────────────────────────────

enum TypeSuivi {
  GROSSESSE
  POST_PARTUM
  NOURRISSON // 0-12 mois
  PEDIATRIQUE // 1-18 ans
  GYNECOLOGIQUE // adulte
  GENERAL
}

model SuiviSpecialise {
  id                     String         @id @default(cuid())
  dossierId              String
  type                   TypeSuivi
  actif                  Boolean        @default(true)
  // ─── Grossesse ───────────────────────────────────────────────
  dateDebutGrossesse     DateTime?
  semainesAmenorhee      Int? // SA calculé
  datePrevueAccouchement DateTime? // DPA
  parite                 String? // ex: "G2P1" (2e grossesse, 1 accouchement)
  // ─── Pédiatrie / Nourrisson ──────────────────────────────────
  dateNaissancePatient   DateTime? // pour calcul âge
  prenomPatient          String? // prénom de l'enfant suivi
  // ─── Biométrie (poids/taille pour courbe croissance) ─────────
  poidsKg                Float? // dernière mesure en kg
  tailleCm               Float? // en cm
  perimCranienCm         Float? // périmètre crânien (nourrisson)
  // ─── Général ──────────────────────────────────────────────────
  notes                  String? // texte libre, chiffré
  examensRealises        String? // JSON: ["Echo T1", "NFS", ...]
  prochainControle       DateTime?
  dossier                DossierMedical @relation(fields: [dossierId], references: [id])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([dossierId, type])
  @@index([dossierId, actif])
}

// ─── Questionnaire Pré-Consultation ──────────────────────────────

model QuestionnairePreConsultation {
  id          String   @id @default(cuid())
  userId      String
  typeSoin    String? // slug du soin concerné
  motif       String // chiffré – raison principale
  antecedents String? // chiffré
  medicaments String? // chiffré
  allergies   String? // chiffré
  ddr         String? // date dernières règles (chiffré, optionnel)
  parite      String? // G/P (grossesses/accouchements) si pertinent
  autresInfos String? // chiffré – informations complémentaires
  traite      Boolean  @default(false) // praticienne a lu le questionnaire
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([traite, createdAt])
}
